// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: students
// Fields: id, name, birthday, gender, grade, className, password, hasChangedPassword, schoolYear
//
// Collection: questions
// Fields: id, grade, subject, type, level, content, imageUrl, imageWidth, options, correctAnswer, subQuestions, schoolYear, examType
//
// Collection: scores
// Fields: id, studentId, studentName, className, grade, subject, score, part1Score, part2Score, part3Score, timestamp, schoolYear, examType
//
// Collection: settings
// Fields: grade, subject, schoolYear, examType, date, startTime, endTime, isActive
//
// Collection: admin
// Document: config
// Fields: password
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Google Auth removed per user request. 
      // In a production app, you should use a more secure method to identify admins.
      return true; 
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Students collection
    match /students/{studentId} {
      allow read: if true; // Allowed for student login list. WARNING: Passwords are visible!
      allow write: if isAdmin();
    }

    // Questions collection
    match /questions/{questionId} {
      allow read: if true; // Everyone can read questions for exams
      allow write: if isAdmin();
    }

    // Scores collection
    match /scores/{scoreId} {
      allow read: if isAdmin();
      allow create: if true; // Students can submit scores
      allow update, delete: if isAdmin();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin config
    match /admin/config {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
